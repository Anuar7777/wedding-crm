# Copy to `backend/.env` for local Nest without Docker.
# Replace placeholders; do not commit real secrets.

DATABASE_URL=
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRATION=
JWT_REFRESH_EXPIRATION=
TELEGRAM_BOT_TOKEN=
PORT=
CORS_ORIGIN=
LOG_LEVEL=
LOG_STACK=
LOG_BODY=
LOG_4XX=

# Optional Prisma seed (yarn prisma db seed). Set both or omit both to skip.
SEED_SUPERADMIN_EMAIL=
SEED_SUPERADMIN_PASSWORD=

# Optional: suggested password in CRM user reset dialog (GET /api/users/reset-password-default).
DEFAULT_RESET_PASSWORD=
