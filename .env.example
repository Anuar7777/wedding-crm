WEDDING_CRM_IMAGE_REGISTRY=ghcr.io/anuar7777
WEDDING_CRM_IMAGE_TAG=main

# Database (used by docker-compose and backend)
POSTGRES_USER=event_crm_user
POSTGRES_PASSWORD=event_crm_password
POSTGRES_DB=event_crm_db
POSTGRES_PORT=5433

DATABASE_URL=postgresql://event_crm_user:event_crm_password@db:5432/event_crm_db

# Services ports on host machine
BACKEND_PORT=3000
FRONTEND_PORT=3001

# Backend app env (values taken from existing backend .env)
JWT_ACCESS_SECRET=dev-access-secret-change-in-production
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
TELEGRAM_BOT_TOKEN=
CORS_ORIGIN=http://localhost:3000,http://localhost:5173
LOG_LEVEL=log,warn,error,debug
LOG_STACK=true
LOG_BODY=false
LOG_4XX=true

# Frontend build env
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
