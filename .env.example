# Copy to `.env` in the repository root and set every variable.
# `docker compose` does not apply default values; missing entries stay empty.

# Docker image names (build + image:)
WEDDING_CRM_IMAGE_REGISTRY=
WEDDING_CRM_IMAGE_TAG=

# PostgreSQL (service `db` in docker-compose.yml, `postgres` in docker-compose-dev.yml)
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_PORT=

# Published host ports
BACKEND_PORT=
FRONTEND_PORT=

# Backend (passed into the backend container)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRATION=
JWT_REFRESH_EXPIRATION=
TELEGRAM_BOT_TOKEN=
CORS_ORIGIN=
LOG_LEVEL=
LOG_STACK=
LOG_BODY=
LOG_4XX=

# Optional backend (see backend/.env.example): pg pool size, trust proxy for rate-limit IP behind nginx.
PG_POOL_MAX=
TRUST_PROXY=

# Optional: first SuperAdmin (Prisma seed). Set both or leave both empty to skip.
# Password must be at least 12 characters. Never commit real values.
SEED_SUPERADMIN_EMAIL=
SEED_SUPERADMIN_PASSWORD=

# Optional: prefills the SuperAdmin “reset password” dialog in CRM (same value for all users).
DEFAULT_RESET_PASSWORD=

# Frontend build arg (URL of the API as reachable from the browser)
NEXT_PUBLIC_API_BASE_URL=
