# Copy to `frontend/.env.local` for `yarn workspace frontend dev`.

# Nest URL for Next rewrites (browser calls same-origin /api/*). Local: http://127.0.0.1:<BACKEND_PORT>
BACKEND_INTERNAL_URL=

# Optional: call the API directly from the browser (skip proxy). Leave empty to use same-origin /api.
NEXT_PUBLIC_API_BASE_URL=

# Site origin for Open Graph absolute URLs (e.g. https://events.example.com). Dev default: http://localhost:3000
NEXT_PUBLIC_SITE_URL=

# Optional: absolute base URLs for invitation QR/links. Leave empty to use same-origin paths.
NEXT_PUBLIC_INVITE_URL_WEDDING=
NEXT_PUBLIC_INVITE_URL_BRIDE=
